#!/bin/sh

# Guard: internal code changes require explicit unlock command.
# Command: pnpm internal:unlock

LOCK_FILE=".internal-edit-unlock"
LOCK_TOKEN="ALLOW_INTERNAL_CODE_CHANGES=1"

is_internal_change() {
  case "$1" in
    packages/*|scripts/*|tests/*|.github/*|.husky/*|package.json|pnpm-lock.yaml|pnpm-workspace.yaml|tsconfig.base.json|eslint.config.js)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

staged_files=$(git diff --cached --name-only --diff-filter=ACMR)
needs_unlock=0

if [ -n "$staged_files" ]; then
  while IFS= read -r file; do
    if is_internal_change "$file"; then
      needs_unlock=1
      break
    fi
  done <<EOF
$staged_files
EOF
fi

if [ "$needs_unlock" -eq 1 ]; then
  if [ ! -f "$LOCK_FILE" ] || ! grep -q "^$LOCK_TOKEN$" "$LOCK_FILE"; then
    echo ""
    echo "ERROR: Internal code edits are locked."
    echo "Run: pnpm internal:unlock"
    echo "Then run git commit again."
    echo ""
    exit 1
  fi
fi

# Gitleaks pre-commit hook
# Scans staged files for secrets before allowing commit
echo "Scanning staged files for secrets..."

if ! command -v gitleaks > /dev/null 2>&1; then
  echo ""
  echo "ERROR: gitleaks is not installed."
  echo ""
  echo "Install gitleaks to enable secret scanning:"
  echo "  macOS:   brew install gitleaks"
  echo "  Linux:   See https://github.com/gitleaks/gitleaks#installing"
  echo ""
  echo "Secret scanning is required to prevent credential leaks."
  echo "Commit blocked until gitleaks is installed."
  echo ""
  exit 1
fi

# Run gitleaks on staged files only
gitleaks protect --staged --verbose

if [ $? -ne 0 ]; then
  echo ""
  echo "ERROR: Secret(s) detected in staged files."
  echo ""
  echo "To fix:"
  echo "  1. Remove the secret from the file"
  echo "  2. Use environment variables instead: \${SECRET_NAME}"
  echo "  3. Add to .env.local (which is in .gitignore)"
  echo "  4. Update agent-orchestrator.yaml.example with placeholder values"
  echo ""
  echo "If this is a false positive, update .gitleaks.toml allowlist"
  echo ""
  exit 1
fi

echo "No secrets detected"

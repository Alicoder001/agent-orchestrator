{
  "name": "@composio/ao-desktop",
  "version": "0.1.0",
  "description": "Desktop foundation package for Agent Orchestrator (Tauri + sidecar runtime primitives)",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src-tauri"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/demo.ts",
    "dev:ui": "vite --host 127.0.0.1 --port 1420",
    "build:ui": "vite build --outDir dist-ui",
    "preview:ui": "vite preview --host 127.0.0.1 --port 1420",
    "dev:desktop": "tsx src/scripts/dev-desktop.ts",
    "preflight:tauri": "tsx src/scripts/preflight-tauri.ts",
    "dev:tauri": "pnpm run preflight:tauri && tsx src/scripts/run-tauri.ts dev",
    "build:tauri": "pnpm run preflight:tauri && tsx src/scripts/run-tauri.ts build",
    "dev:sidecar": "tsx src/sidecar/main.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.ui.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@composio/ao-core": "workspace:*",
    "@tauri-apps/api": "^2.8.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.1.0",
    "@types/node": "^25.2.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^7.1.7",
    "vitest": "^4.0.18"
  }
}
